{
  "version": "1.1",
  "description": "Configuration des sources Open Data pour PRISME (alternative à MOCA-O)",
  "lastUpdated": "2026-04-17",

  "sources": {
    "insee_diplomes_formation": {
      "name": "INSEE Base infracommunale Diplômes-Formation",
      "provider": "INSEE",
      "baseUrl": "https://www.insee.fr/fr/statistiques/fichier",
      "years": {
        "2022": "/8647010/base-ic-diplomes-formation-2022_csv.zip",
        "2021": "/8268840/base-ic-diplomes-formation-2021_csv.zip",
        "2020": "/7704080/base-ic-diplomes-formation-2020_csv.zip",
        "2019": "/6543298/base-ic-diplomes-formation-2019_csv.zip",
        "2018": "/5650712/base-ic-diplomes-formation-2018_csv.zip",
        "2017": "/4799252/base-ic-diplomes-formation-2017_csv.zip"
      },
      "encoding": "utf-8",
      "separator": ";",
      "geoColumn": "COM",
      "irisColumn": "IRIS",
      "variables": {
        "pop_6_16": {
          "formula": "P{YY}_POP0610 + P{YY}_POP1114 + P{YY}_POP1517 * 0.666",
          "description": "Population 6-16 ans"
        },
        "nb_non_sco": {
          "formula": "(P{YY}_POP0610 - P{YY}_SCOL0610) + (P{YY}_POP1114 - P{YY}_SCOL1114) + (P{YY}_POP1517 - P{YY}_SCOL1517) * 0.666",
          "description": "Jeunes 6-16 ans non scolarisés"
        },
        "pop_15_64": {
          "formula": "P{YY}_POP1524 + P{YY}_POP2554 + P{YY}_POP5564",
          "fallback": "P{YY}_POP1517 + P{YY}_POP1824 + P{YY}_POP2529 + P{YY}_POP30P * 0.88",
          "description": "Population 15-64 ans"
        },
        "nb_peu_dipl": {
          "formula": "P{YY}_NSCOL15P_DIPLMIN",
          "fallback": "P{YY}_NSCOL15P",
          "description": "Personnes 15+ peu ou pas diplômées"
        }
      },
      "providesDatasets": ["educ"]
    },

    "insee_couples_familles_menages": {
      "name": "INSEE Base infracommunale Couples-Familles-Ménages",
      "provider": "INSEE",
      "baseUrl": "https://www.insee.fr/fr/statistiques/fichier",
      "years": {
        "2022": "/8647008/base-ic-couples-familles-menages-2022_csv.zip",
        "2021": "/8268828/base-ic-couples-familles-menages-2021_csv.zip",
        "2020": "/7704086/base-ic-couples-familles-menages-2020_csv.zip",
        "2019": "/6543224/base-ic-couples-familles-menages-2019_csv.zip",
        "2018": "/5650714/base-ic-couples-familles-menages-2018_csv.zip",
        "2017": "/4799268/base-ic-couples-familles-menages-2017_csv.zip"
      },
      "encoding": "utf-8",
      "separator": ";",
      "geoColumn": "COM",
      "variables": {
        "nb_pop_65ans": {
          "formula": "P{YY}_POP65P",
          "description": "Population 65 ans et plus"
        },
        "nb_pop_65ans_seule": {
          "formula": "C{YY}_PMEN_MENPSEUL65P",
          "fallback": "C{YY}_MEN_PMEN1 * 0.3",
          "description": "Personnes seules 65 ans et plus"
        },
        "nb_familles_enf": {
          "formula": "C{YY}_FAM_COUPAENF + C{YY}_FAM_MONO",
          "description": "Familles avec enfant(s) < 25 ans"
        },
        "nb_familles_mono_enf": {
          "formula": "C{YY}_FAM_MONO",
          "fallback": "C{YY}_MENFAMMONO",
          "description": "Familles monoparentales avec enfant(s)"
        },
        "pop_inf3ans": {
          "formula": "P{YY}_POP0002",
          "description": "Population moins de 3 ans"
        },
        "nb_menages_total": {
          "formula": "C{YY}_MEN",
          "description": "Nombre total de ménages"
        }
      },
      "providesDatasets": ["pers_sup65ans_seules", "familles_mono", "pop_inf3ans", "pers_menages", "types_menages"]
    },

    "insee_populations_legales": {
      "name": "INSEE Populations légales",
      "provider": "INSEE",
      "baseUrl": "https://www.insee.fr/fr/statistiques/fichier",
      "years": {
        "2023": "/8680726/ensemble.zip",
        "2022": "/8290591/ensemble.zip",
        "2021": "/7739582/ensemble.zip"
      },
      "encoding": "utf-8",
      "separator": ";",
      "geoColumn": "CODGEO",
      "variables": {
        "population_municipale": {
          "formula": "PMUN",
          "description": "Population municipale"
        },
        "population_totale": {
          "formula": "PTOT",
          "description": "Population totale"
        }
      },
      "providesDatasets": ["densite", "structure_pop"]
    },

    "insee_naissances": {
      "name": "INSEE État civil - Naissances",
      "provider": "INSEE",
      "baseUrl": "https://www.insee.fr/fr/statistiques/fichier",
      "years": {
        "2024": "/8582142/reg_dep_naissances_2024.zip",
        "2023": "/7673429/reg_dep_naissances_2023.zip",
        "2022": "/7673429/reg_dep_naissances_2022.zip"
      },
      "encoding": "utf-8",
      "separator": ";",
      "geoLevel": "regional",
      "note": "Données régionales uniquement, pas au niveau communal",
      "providesDatasets": ["indice_fecondite"]
    },

    "data_gouv_ircom": {
      "name": "IRCOM - Impôt sur le revenu par collectivité",
      "provider": "DGFiP via data.gouv.fr",
      "url": "https://www.data.gouv.fr/fr/datasets/impot-sur-le-revenu-par-commune-ircom/",
      "directDownload": "https://www.data.gouv.fr/fr/datasets/r/23c55b31-74c2-4669-9815-84b79d7c5d8f",
      "encoding": "utf-8",
      "separator": ";",
      "geoColumn": "code_commune",
      "variables": {
        "nb_foyers_non_impo": {
          "column": "foyers_non_imposables",
          "description": "Foyers fiscaux non imposables"
        },
        "nb_foyers_imposes": {
          "column": "foyers_imposables",
          "description": "Foyers fiscaux imposables"
        }
      },
      "providesDatasets": ["revenu"]
    },

    "baac_onisr": {
      "name": "BAAC — Bases annuelles des accidents corporels de la circulation (ONISR)",
      "provider": "Ministère de l'Intérieur / ONISR",
      "url": "https://www.data.gouv.fr/datasets/bases-de-donnees-annuelles-des-accidents-corporels-de-la-circulation-routiere-annees-de-2005-a-2024/",
      "localRoot": "inputs/opendata/baac",
      "structure": "annees_{YYYY}/{caract|usagers|vehicules|lieux}_{YYYY}.csv",
      "years": ["2019", "2020", "2021", "2022", "2023", "2024"],
      "encoding": "utf-8",
      "separator": ";",
      "geoColumns": {"dep": "dep", "com": "com"},
      "variables": {
        "nb_acci": {
          "source": "caract",
          "formula": "COUNT(DISTINCT Num_Acc)",
          "description": "Nombre d'accidents corporels"
        },
        "nb_blesses": {
          "source": "usagers",
          "formula": "COUNT(grav IN (3,4))",
          "description": "Nombre de blessés (hospitalisés + légers)"
        },
        "nb_morts": {
          "source": "usagers",
          "formula": "COUNT(grav = 2)",
          "description": "Nombre de tués"
        }
      },
      "providesDatasets": ["route"]
    },

    "spf_noyades_odisse": {
      "name": "Enquête NOYADES — Santé Publique France (portail Odissé)",
      "provider": "Santé Publique France",
      "url": "https://odisse.santepubliquefrance.fr/explore/dataset/noyade-nombre-de-noyades-et-deces/",
      "apiEndpoint": "https://odisse.santepubliquefrance.fr/api/explore/v2.1/catalog/datasets/noyade-nombre-de-noyades-et-deces/exports/csv",
      "localFile": "inputs/opendata/spf_noyades/noyades_departement_2003_2021.csv",
      "encoding": "utf-8",
      "separator": ";",
      "geoColumn": "Département Code",
      "yearsAvailable": [2003, 2004, 2006, 2009, 2012, 2015, 2018, 2021],
      "note": "Enquête triennale depuis 2006. Années 2022-2024 disponibles uniquement en bilans PDF — template manuel fourni dans csv_sources/noyades_template.csv",
      "variables": {
        "nb_noyades": {
          "column": "Nombre de noyades accidentelles",
          "description": "Nombre total de noyades"
        },
        "nb_noyades_deces": {
          "column": "Nombres de noyades accidentelles suivies de décès",
          "description": "Décès par noyade"
        }
      },
      "providesDatasets": ["noyades"]
    },

    "cepidc_mortalite_comportementale": {
      "name": "Mortalité comportementale — CépiDc via Odissé + CSV sources manuels",
      "provider": "CépiDc INSERM / Santé Publique France / Odissé",
      "localRoot": "inputs/opendata/cepidc/mortalite_causes_comportementales",
      "sources": {
        "suicides_departement": {
          "file": "suicides_deces_departement.csv",
          "url": "https://odisse.santepubliquefrance.fr/explore/dataset/suicides-deces-departement/",
          "years": "2019-2023",
          "cim10": "X60-X84",
          "columns": {"dep": "Département Code", "annee": "Année", "nb": "Nombre de décès"},
          "variable": "m_suicide"
        },
        "suicides_region": {
          "file": "suicides_deces_region.csv",
          "url": "https://odisse.santepubliquefrance.fr/explore/dataset/suicides-deces-region/",
          "years": "2019-2023",
          "cim10": "X60-X84",
          "variable": "m_suicide"
        },
        "alcool_consommation_region": {
          "file": "alcool_consommation_quotidienne_region.csv",
          "url": "https://odisse.santepubliquefrance.fr/explore/dataset/alcool-consommation-quotidienne-region/",
          "years": "2000-2023",
          "note": "CONSOMMATION (prévalence), PAS mortalité — proxy uniquement pour m_alcool",
          "variable": "m_alcool_proxy"
        },
        "tabac_consommation_region": {
          "file": "tabac_consommation_quotidienne_region.csv",
          "url": "https://odisse.santepubliquefrance.fr/explore/dataset/tabac-consommation-quotidienne_reg/",
          "years": "2000-2023",
          "note": "CONSOMMATION (prévalence), PAS mortalité — proxy uniquement pour m_tabac",
          "variable": "m_tabac_proxy"
        }
      },
      "todo": [
        "Mortalité directe alcool (F10, K70, K73, K74, K86) par département : pas en CSV Odissé — export manuel CépiDc requis",
        "Mortalité directe tabac (C33-C34, F17) par département : idem",
        "Demande à soumettre à CépiDc INSERM ou parsing Selenium opendata-cepidc.inserm.fr"
      ],
      "providesDatasets": ["mortalite_comportementale"]
    },

    "cafdata_allocataires": {
      "name": "CAF Data - Allocataires par commune",
      "provider": "CNAF",
      "apiEndpoint": "https://data.caf.fr/api/explore/v2.1/catalog/datasets/s_ben_com_f/exports/csv",
      "params": {
        "lang": "fr",
        "timezone": "Europe/Paris",
        "delimiter": ";"
      },
      "encoding": "utf-8",
      "separator": ";",
      "geoColumn": "code_commune",
      "variables": {
        "nb_alloc": {
          "column": "Nbre_foyers_alloc_total",
          "description": "Nombre de foyers allocataires"
        },
        "nb_personnes_couvertes": {
          "column": "Nbre_pers_couv_total",
          "description": "Personnes couvertes par prestations CNAF"
        }
      },
      "providesDatasets": ["alloc"]
    }
  },

  "datasetMappings": {
    "pop_inf3ans": {
      "source": "insee_couples_familles_menages",
      "outputColumns": ["pop_inf3ans", "rp"],
      "formula": {
        "pop_inf3ans": "P{YY}_POP0002 (fallback: (C{YY}_NE24F1 + 2*C{YY}_NE24F2 + 3*C{YY}_NE24F3 + 4*C{YY}_NE24F4P) * 0.12)",
        "rp": "P{YY}_POP (fallback: C{YY}_PMEN)"
      }
    },
    "pers_menages": {
      "source": "insee_couples_familles_menages",
      "outputColumns": ["nb_menages", "nb_pers_menages"],
      "formula": {
        "nb_menages": "C{YY}_MEN",
        "nb_pers_menages": "C{YY}_PMEN"
      }
    },
    "types_menages": {
      "source": "insee_couples_familles_menages",
      "outputColumns": ["nb_men_seul", "nb_men_couple_senf", "nb_men_couple_aenf", "nb_men_fam_mono"],
      "formula": {
        "nb_men_seul": "C{YY}_MENPSEUL",
        "nb_men_couple_senf": "C{YY}_MENCOUPSENF",
        "nb_men_couple_aenf": "C{YY}_MENCOUPAENF",
        "nb_men_fam_mono": "C{YY}_MENFAMMONO"
      }
    },
    "alloc": {
      "source": "cafdata_allocataires",
      "outputColumns": ["nb_alloc", "nb_menages"],
      "formula": {
        "nb_alloc": "CAF: Nombre foyers NDUR (fallback: Nbre_foyers_alloc_total)",
        "nb_menages": "INSEE Couples-Familles-Menages: C{YY}_MEN (jointure par commune)"
      }
    },
    "revenu": {
      "source": "data_gouv_ircom",
      "outputColumns": ["nb_foyers_non_impo", "nb_foyers_imposes"],
      "formula": {
        "nb_foyers_non_impo": "foyers_non_imposables (fallback: nb_foyers_non_impo)",
        "nb_foyers_imposes": "foyers_imposables (fallback: nb_foyers_imposes)"
      }
    },
    "densite": {
      "source": "insee_populations_legales",
      "outputColumns": ["rp", "superficie"],
      "formula": {
        "rp": "PMUN (fallback: PTOT)",
        "superficie": "superficie (fallback: SUPERFICIE | surface_km2 | surface)"
      }
    },
    "route": {
      "source": "baac_onisr",
      "outputColumns": ["nb_acci", "nb_blesses", "nb_morts"],
      "formula": {
        "nb_acci": "caract: COUNT(DISTINCT Num_Acc) par (annee, dep, com)",
        "nb_blesses": "usagers: COUNT(grav IN (3,4)) joint sur Num_Acc",
        "nb_morts": "usagers: COUNT(grav = 2) joint sur Num_Acc"
      },
      "note": "Niveaux géo : COM (caract.com), DEP (caract.dep), REG (mapping DEP→REG), FR entière"
    },
    "noyades": {
      "source": "spf_noyades_odisse",
      "outputColumns": ["nb_noyades", "nb_noyades_deces"],
      "formula": {
        "nb_noyades": "Nombre de noyades accidentelles (dep + annee)",
        "nb_noyades_deces": "Nombres de noyades accidentelles suivies de décès"
      },
      "note": "Niveau DEP uniquement (pas de ventilation communale). Années disponibles : 2003,04,06,09,12,15,18,21. Template manuel pour 2022-2024 : csv_sources/noyades_template.csv"
    },
    "mortalite_comportementale": {
      "source": "cepidc_mortalite_comportementale",
      "outputColumns": ["m_suicide", "m_alcool", "m_tabac"],
      "formula": {
        "m_suicide": "suicides_deces_departement.csv: SUM(Nombre de décès) par (Année, Département Code)",
        "m_alcool": "TODO — CépiDc F10,K70,K73,K74,K86 non disponible en Open Data automatisée (proxy consommation région)",
        "m_tabac": "TODO — CépiDc C33-C34,F17 non disponible en Open Data automatisée (proxy consommation région)"
      },
      "note": "m_suicide OK niveau DEP 2019-2023. m_alcool/m_tabac : export manuel CépiDc requis (voir csv_sources/README_TRAUMATISMES.md)"
    }
  },

  "datasetsRequiringMocaO": {
    "fecondite": {
      "reason": "Données par tranche d'âge de la mère au niveau communal non disponibles en Open Data",
      "variables": ["tx_fecondite", "nb_naiss_vivante"],
      "alternative": "Utiliser données régionales INSEE pour approximation"
    },
    "emplois_csp": {
      "reason": "Catégories socio-professionnelles détaillées (ouvriers/cadres) non disponibles par commune",
      "variables": ["nb_ouvriers", "nb_cadres"],
      "alternative": "Utiliser ratios régionaux ou données emploi générales"
    }
  },

  "geoFilters": {
    "guyane": {
      "communeCodes": ["97301", "97302", "97303", "97304", "97305", "97306", "97307", "97308", "97309", "97310", "97311", "97312", "97313", "97314", "97352", "97353", "97356", "97357", "97358", "97360", "97361", "97362"],
      "regionCode": "03",
      "departementCode": "973"
    }
  }
}
